# Copy this file to .env and fill in your values
# Do NOT commit .env to git

# PostgreSQL connection string (from Neon, Supabase, etc.)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# JWT secret — use any long random string (32+ chars)
JWT_SECRET_KEY="replace-with-a-long-random-secret-key"

# Gemini API key (from https://aistudio.google.com/apikey)
GEMINI_API_KEY="your-gemini-api-key"

# Plant.id API key (from https://plant.id)
PLANTID_API_KEY="your-plantid-api-key"
